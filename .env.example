# scubaSeason.fun — affiliate tracking IDs
# Copy this file to .env.local for local dev, or set on Vercel
# (Project Settings → Environment Variables) for production.
#
# Empty values are safe — affiliate links fall back to untagged URLs
# when an ID is missing. Set each value as that program approves you.
#
# See docs/affiliate-setup.md for where to get each ID.

# Amazon Associates — gear affiliate
# Format: "yourtag-20" (US program). Found in Associate Central.
NEXT_PUBLIC_AMAZON_TAG=

# Booking.com Partner Hub — lodging affiliate
# Format: 6-7 digit numeric ID. Found in Partner Hub → Reports → Tools.
NEXT_PUBLIC_BOOKING_AID=

# PADI Travel Affiliate Program
# Format: partner slug (assigned on approval).
NEXT_PUBLIC_PADI_PARTNER=

# Travelpayouts (gateway for Skyscanner + other flight/hotel partners)
# Format: numeric marker ID. Found in Travelpayouts dashboard.
NEXT_PUBLIC_TRAVELPAYOUTS_AID=

# Liveaboard.com / LiveaboardBookings.com partner ID
# Format: partner ID assigned on approval.
NEXT_PUBLIC_LIVEABOARD_AID=

# DiveBooker — 180-day cookie program
# Format: partner reference assigned on approval.
NEXT_PUBLIC_DIVEBOOKER_PID=

# SCUBAPRO affiliate program (gear, 10% commission)
# Format: partner ID assigned on approval.
NEXT_PUBLIC_SCUBAPRO_AID=

# Global Fishing Watch — free non-commercial API token.
# Used by scripts/fetch-fishing-pressure.mjs to ingest apparent fishing
# effort within 50km of every dive location.
# Register at https://globalfishingwatch.org/our-apis/ for a free token.
# Leave empty to skip the ingest gracefully — the build still passes.
GFW_API_TOKEN=

# IUCN Red List — free API key for the v4 API.
# Used by scripts/fetch-iucn-status.mjs to refresh species threat
# categories for every species we feature.
# Register at https://api.iucnredlist.org/ for a free key.
# Leave empty to skip the ingest gracefully — the build still passes
# using the seeded src/data/iucn-status.json values.
IUCN_API_KEY=
